# Base
NODE_ENV=production
PORT=3030
APP_SECRET_KEY=change-me-in-prod

# Persistence
PERSISTENCE_DRIVER=memory
# For postgres driver, set DATABASE_URL like:
# postgres://USER:PASS@HOST:5432/DBNAME
# DATABASE_URL=
PERSISTENCE_FLUSH_INTERVAL_MS=60000

# Object storage
OBJECT_STORAGE_DRIVER=local
OBJECT_STORAGE_BUCKET=app
OBJECT_STORAGE_LOCAL_DIR=./data/object-storage
OBJECT_STORAGE_PUBLIC_BASE=/storage/objects
# For Supabase adapter
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# For S3-compatible adapter
# S3_REGION=
# S3_ENDPOINT=

# Video job executor (in-memory worker)
VIDEO_JOB_EXECUTOR_ENABLED=true
VIDEO_JOB_EXECUTOR_INTERVAL_MS=200

# Video generation settings
VIDEO_DURATION=5
VIDEO_RESOLUTION=1080p
VIDEO_ASPECT_RATIO=9:16

# Video polling strategy
VIDEO_POLL_MAX_ATTEMPTS=60
VIDEO_POLL_INTERVAL_MS=5000
VIDEO_POLL_MIN_INTERVAL_MS=2000
VIDEO_POLL_MAX_INTERVAL_MS=10000
VIDEO_POLL_TIMEOUT_MS=300000

# Video retry strategy
VIDEO_CREATE_MAX_RETRIES=2
VIDEO_CREATE_RETRY_DELAY_MS=3000
VIDEO_OVERLOAD_RETRY_DELAY_MS=30000
VIDEO_PENDING_RETRY_DELAY_MS=3000
VIDEO_JOB_RETRIES=3
VIDEO_JOB_TIMEOUT_MINUTES=10
VIDEO_JOB_RETRY_BASE_DELAY_MS=30000
VIDEO_JOB_RETRY_MAX_DELAY_MS=300000
VIDEO_JOB_RETRY_JITTER_MS=10000

# Video model candidates (comma-separated, by priority)
VIDEO_MODEL_CANDIDATES=veo3.1,veo3.1-fast,doubao-seedance-1-5-pro-251215,jimeng-video-3.1,jimeng-video-3.0

# Dev bootstrap admin (must provide both keys together; forbidden in production)
DEV_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
DEV_BOOTSTRAP_ADMIN_PASSWORD=admin123

# Reverse fetch order and external API priority
REVERSE_FETCH_STAGE_ORDER=S5_EXTERNAL_API,S1_CUSTOM_COOKIE,S2_PUBLIC_POOL,S3_PLAYWRIGHT_GUEST,S4_USER_QR_COOKIE,S6_LOCAL_FILE
REVERSE_EXTERNAL_API_PRIORITY=apify,tikhub,anytocopy

# External reverse API endpoints
APIFY_REVERSE_API_URL=https://api.apify.com/v2/acts/apple_yang~douyin-transcripts-scraper/run-sync-get-dataset-items
APIFY_API_TOKEN=
TIKHUB_REVERSE_API_URL=https://api.tikhub.io/api/v1/douyin/web/fetch_video_high_quality_play_url
TIKHUB_API_TOKEN=
ANYTOCOPY_REVERSE_API_URL=
ANYTOCOPY_API_TOKEN=

# 图片/视频基础URL（用于拼接相对路径）
HOST_BASE_URL=https://www.neirongmiao.com

# Trend source endpoints
TIKHUB_VIDEO_HOT_API_URL=https://api.tikhub.io/api/v1/douyin/billboard/fetch_hot_total_low_fan_list
TIKHUB_REALTIME_HOT_API_URL=https://api.tikhub.io/api/v1/douyin/billboard/fetch_hot_total_list
DOUHOT_VIDEO_LIST_ENDPOINT=https://douhot.douyin.com/square/hotspot
DOUYIN_HOT_HUB_README_URL=https://raw.githubusercontent.com/lonnyzhang423/douyin-hot-hub/main/README.md

# Douyin auto-publish (via social-auto-upload)
DOUYIN_PUBLISH_ENABLED=false
SOCIAL_AUTO_UPLOAD_DIR=
DOUYIN_COOKIE_DIR=
# Legacy alias, kept for compatibility during migration.
DOUYIN_COOKIE_FILE=
DOUYIN_PUBLISH_HISTORY_STORE_PATH=data/douyin-publish-history.json
DOUYIN_QR_HEADLESS=true
DOUYIN_REMOTE_LOGIN_ENABLED=false
DOUYIN_REMOTE_LOGIN_XPRA_BIN=xpra
DOUYIN_REMOTE_LOGIN_CHROME_BIN=
DOUYIN_REMOTE_LOGIN_BIND_HOST=127.0.0.1
DOUYIN_REMOTE_LOGIN_PUBLIC_URL_TEMPLATE=
DOUYIN_REMOTE_LOGIN_PORT_START=14500
DOUYIN_REMOTE_LOGIN_PORT_END=14599
DOUYIN_REMOTE_LOGIN_DISPLAY_START=100
DOUYIN_REMOTE_LOGIN_DISPLAY_END=199
DOUYIN_REMOTE_LOGIN_SESSION_TIMEOUT_MS=900000
