{
  "manifest_version": 3,
  "name": "内容喵 · 抖音发布助手",
  "version": "1.0.0",
  "description": "通过 Chrome 扩展自动化发布短视频到抖音创作者后台",
  "key": "",
  "permissions": [
    "cookies",
    "storage",
    "tabs",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://creator.douyin.com/*",
    "https://*.douyin.com/*",
    "https://*.iesdouyin.com/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://creator.douyin.com/*"
      ],
      "js": ["src/content/douyin-creator.ts"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "src/assets/icon-16.png",
      "48": "src/assets/icon-48.png",
      "128": "src/assets/icon-128.png"
    }
  },
  "options_page": "src/options/index.html",
  "externally_connectable": {
    "matches": [
      "https://*.neirongmiao.com/*",
      "http://localhost:*/*"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["https://creator.douyin.com/*"]
    }
  ]
}
