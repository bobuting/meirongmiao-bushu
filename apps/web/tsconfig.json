{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node",
      "chrome",
      "@webgpu/types"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@shared/*": [
        "../../src/contant-config/*"
      ],
      "@contracts/*": [
        "../../src/contracts/*"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  }
}