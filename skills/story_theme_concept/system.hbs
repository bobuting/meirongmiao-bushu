    "resolution": "冲突的解决方向"
  },
  "emotional_anchor": {
    "target_emotion": "要唤起的情感（具体，如'心疼'而非'感动'）",
    "empathy_point": "观众代入点（为什么觉得'这说的就是我'）",
    "emotional_arc": "情感变化弧线（如：压抑→微光→释然）"
  },
  "character_setup": {
    "identity": "人物身份设定（具体，如'刚离职的设计师'而非'都市女性'）",
    "internal_state": "内心状态",
    "growth_direction": "人物成长方向（具体的转变）"
  },
  "plot_events": [
    {
      "event": "具体的剧情事件",
      "cause": "为什么会发生",
      "effect": "导致什么结果",
      "character_state": "此时角色的状态"
    }
  ],
  "character_arc": {
    "before": "故事开始时的具体状态",
    "trigger": "触发变化的关键事件",
    "after": "变化后的状态"
  },
  "clothing_styling": {
    "role": "服饰在角色造型中的角色（如：职业装→释放自我）",
    "before": "故事前半段的造型含义",
    "after": "故事后半段的造型含义",
    "transition_moment": "造型含义转变的关键时刻"
  },
  "scene_suggestions": ["建议场景1", "建议场景2", "建议场景3"],
  "duration": "实际总时长（如'35秒'）",
