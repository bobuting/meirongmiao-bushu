## 输出格式

**只输出纯 JSON，不输出任何其他内容。**

```json
{
  "outline_id": "大纲唯一标识",
  "theme_title": "{{themeTitle}}",
  "conflict": "{{conflictCore}}",
  "emotion_arc": "{{emotionalArc}}",
  "story_summary": "50-80字故事概要，描述完整的剧情过程（有事件、有因果、有变化）",
  "story_structure": {
    "setup": "起因：什么打破了角色的日常",
    "turning_point": "转折：什么事件改变了走向",
    "climax": "高潮：角色面临的关键时刻",
    "resolution": "结局：新的状态如何落定"
  },
  "event_chain": [
    {
      "event_index": 0,
      "shots": [1, 2],
      "causes_next": "本事件如何推动下一个事件"
    }
  ],
  "character_styling_arc": {
    "before_state": "服饰配合角色初始状态的含义",
    "transition_shot": 3,
    "after_state": "服饰配合角色变化后状态的含义",
    "visual_change": "造型的视觉变化描述"
  },
  "shots_outline": [
    {
      "shot_number": 1,
      "duration_seconds": 4,
      "scene": "具体场景（有细节，如'深夜便利店货架前'而非'室内'）",
      "emotion": "本镜头情绪（具体，如'疲惫中的麻木'而非'难过'）",
      "action": "人物具体动作（可拍摄的真实动作）",
      "clothing_role": "服饰在本镜头的角色造型含义",
      "narrative_purpose": "本镜头在故事中的作用",
      "serves_event": "本镜头服务的剧情事件（与 plot_events 对应）",
      "dialogue_or_narration": "旁白（最多8字）或无"
    }
  ]
}
```

