    {"point": "纯棉面料透气亲肤，适合四季穿着", "category": "面料", "priority": 1},
    {"point": "宽松版型不挑身材，包容性强", "category": "版型", "priority": 1}
  ],
  "multiViewWarning": "多视角警告信息或null"
